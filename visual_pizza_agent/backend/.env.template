# This file is used as a template for local development and testing.
# Copy this file to .env and replace the placeholder values with your actual credentials.

# Use Vertex AI instead of Google AI Studio
GOOGLE_GENAI_USE_VERTEXAI=1

# Replace with your actual Google Cloud Project ID and Location
GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# The location where the target model is available (used to override the Agent Engine compute location for preview models)
MODEL_LOCATION=global

# Enable capturing full prompt and response content in traces
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=true
